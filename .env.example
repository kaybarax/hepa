# HEPA local configuration template.
# Copy to .env for local development; never commit local credentials.

HEPA_CONTROL_ROOT=.hepa
HEPA_WORKTREE_ROOT=.hepa/worktrees
HEPA_ARCHIVE_ROOT=.hepa/archive

HEPA_MAX_TOTAL_ROUNDS=3
HEPA_MAX_REPAIR_ROUNDS=2

HEPA_NOTIFY_TERMINAL=true
HEPA_NOTIFY_COMMAND=

HEPA_DEFAULT_ADAPTER=fake
HEPA_ROUTING_FILE=.hepa/routing.yaml

# Pi Coding Agent defaults. Set HEPA_DEFAULT_ADAPTER=pi after installing Pi.
HEPA_PI_MODEL=deepseek/deepseek-chat
HEPA_PI_REVIEW_MODEL=
HEPA_PI_PROVIDER_KEY_ENV=DEEPSEEK_API_KEY
HEPA_PI_BASE_URL=

# Provider keys are worker/reviewer adapter env, not manager credentials.
DEEPSEEK_API_KEY=

HEPA_HERMES_ENABLED=true
HEPA_HERMES_ENDPOINT=
HEPA_HERMES_BOARD_ID=
HEPA_HERMES_SYNC_INTERVAL_SECONDS=30
